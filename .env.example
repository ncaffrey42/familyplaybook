# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
#
# Used by both workflows:
#   Local dev  →  npm run dev            (Vite reads .env.local automatically)
#   Docker dev →  docker compose -f docker-compose.dev.yml up
#   Docker prod→  docker compose up --build  (values are baked into the build)

# -------------------------------------------------------
# Supabase
# Found in: Supabase dashboard > Project Settings > API
# -------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------------------
# App URL
# Local dev:   http://localhost:3000
# Docker dev:  http://localhost:3000
# Production:  https://your-domain.com   ← update before a production build
# Used for auth redirects and share-link generation.
# -------------------------------------------------------
VITE_APP_URL=http://localhost:3000

# -------------------------------------------------------
# Stripe (public/publishable key only — used client-side)
# Secret key lives in Supabase edge function secrets, NOT here.
# Found in: Stripe dashboard > Developers > API Keys
# Leave blank to disable Stripe UI in local dev.
# -------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# -------------------------------------------------------
# Feature flags
# Set to true to enable AI guide-generation features.
# Requires OPENAI_API_KEY to be set as a Supabase edge function secret.
# Defaults to false in Docker production builds if not set.
# -------------------------------------------------------
VITE_ENABLE_AI_GENERATION=false

# -------------------------------------------------------
# Supabase Edge Function Secrets  (set via: supabase secrets set)
# These are NOT prefixed with VITE_ — they are server-only and
# must never appear in this file or be committed to the repo.
# Run: supabase secrets set STRIPE_SECRET_KEY=sk_test_... etc.
# -------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your-signing-secret-here
# STRIPE_PRICE_COUPLE_MONTH=price_...
# STRIPE_PRICE_COUPLE_YEAR=price_...
# STRIPE_PRICE_FAMILY_MONTH=price_...
# STRIPE_PRICE_FAMILY_YEAR=price_...
# OPENAI_API_KEY=sk-...
# APP_URL=https://your-domain.com
