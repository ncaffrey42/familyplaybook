# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# -------------------------------------------------------
# Supabase
# Found in: Supabase dashboard > Project Settings > API
# -------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------------------
# App
# The URL this app is served from (used for auth redirects)
# -------------------------------------------------------
VITE_APP_URL=http://localhost:3000

# -------------------------------------------------------
# Stripe (public/publishable key only — used client-side)
# Secret key lives in Supabase edge function secrets, NOT here
# Found in: Stripe dashboard > Developers > API Keys
# -------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# -------------------------------------------------------
# Supabase Edge Function Secrets (set via: supabase secrets set)
# These are NOT prefixed with VITE_ — they are server-only.
# Run: supabase secrets set STRIPE_SECRET_KEY=sk_test_... etc.
# -------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your-signing-secret-here
# STRIPE_PRICE_COUPLE_MONTH=price_...
# STRIPE_PRICE_COUPLE_YEAR=price_...
# STRIPE_PRICE_FAMILY_MONTH=price_...
# STRIPE_PRICE_FAMILY_YEAR=price_...
# APP_URL=https://your-domain.com

# -------------------------------------------------------
# Feature flags (optional)
# -------------------------------------------------------
VITE_ENABLE_AI_GENERATION=true
